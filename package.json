{
	"name": "ogfrontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "node_modules/.bin/vite dev",
		"build": "node_modules/.bin/vite build",
		"preview": "node_modules/.bin/vite preview",
		"prepare": "node_modules/.bin/svelte-kit sync || echo ''",
		"check": "node_modules/.bin/svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "node_modules/.bin/svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"three": "^0.183.2"
	}
}
